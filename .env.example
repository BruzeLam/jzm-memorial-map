# 复制为 .env.local 用于本地开发；Vercel 项目 Settings → Environment Variables 同样配置

# Supabase（Project Settings → API）
REACT_APP_SUPABASE_URL=https://xxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJ...

# 超级管理员邮箱（须与 supabase/schema.sql 中 RLS 策略一致）
REACT_APP_ADMIN_EMAIL=your@email.com

# 随缘打赏 · Stripe Payment Link 三档（USD）
# 图样图森破 $1 · 续一秒 $8.17 · 谈笑风生 $19.26
# 单一链接含多 SKU 时填 REACT_APP_STRIPE_TIP_URL；也可为每档单独配置 _001 / _817 / _1926
REACT_APP_STRIPE_TIP_URL=https://buy.stripe.com/test_dRm8wP9SY0AO1LdgEAeME02
# REACT_APP_STRIPE_TIP_URL_001=
# REACT_APP_STRIPE_TIP_URL_817=
# REACT_APP_STRIPE_TIP_URL_1926=

# 高德 Web 服务 Key（地点搜索 · 国内 POI，可选但强烈建议）
# 控制台 https://console.amap.com/ → 应用管理 → 创建 Key → 服务平台选「Web 服务」
# 本地开发：填 REACT_APP_AMAP_KEY；生产推荐 Vercel 填 AMAP_WEB_SERVICE_KEY（走 /api/amap 代理，Key 不暴露）
REACT_APP_AMAP_KEY=
# AMAP_WEB_SERVICE_KEY=   # 仅 Vercel 服务端，勿加 REACT_APP_ 前缀

# 智能导览（DeepSeek · 可选）
# 在 https://platform.deepseek.com/ 申请 API Key，仅配置在 Vercel 环境变量（勿加 REACT_APP_ 前缀）
# 本地测试导览：vercel dev（CRA npm start 不会代理 /api/chat）
# DEEPSEEK_API_KEY=

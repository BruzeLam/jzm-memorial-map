# 作品集镜像站环境变量示例
# 复制为 .env.local 或在 Vercel 新建独立项目中配置

# 开启作品集模式（淡化品牌与敏感内容）
REACT_APP_PORTFOLIO_MODE=true

# 使用内置演示数据，不连接生产 Supabase（推荐面试展示）
REACT_APP_PORTFOLIO_DEMO_DATA=true

# 若要在作品集站演示真实云端 CRUD，设为 false 并配置独立 Supabase 项目：
# REACT_APP_PORTFOLIO_DEMO_DATA=false
# REACT_APP_SUPABASE_URL=https://your-demo-project.supabase.co
# REACT_APP_SUPABASE_ANON_KEY=your-anon-key
# REACT_APP_ADMIN_EMAIL=your@email.com
